{
    "name": "solstice-project-backend",
    "version": "1.0.0",
    "scripts": {
        "build": "tsc && cd client && yarn install && yarn build",
        "start": "node dist/server.js",
        "test": "jest NODE_ENV=test --coverage --detectOpenHandles tests",
        "dev": "concurrently \"cd client && yarn start\" \"nodemon server.ts\"",
