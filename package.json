        "arweave": "^1.10.18",
        "canvas": "2.6.1",
        "cors": "^2.8.5",
        "cross-fetch": "^3.1.4",
        "ddos": "^0.2.1",
        "express": "^4.16.4",
        "firebase": "^9.5.0",
        "node-p5": "^1.0.4",
        "seedrandom": "^3.0.5",
        "tslog": "^3.2.2",
        "typescript": "^4.4.4"
    },
    "devDependencies": {
        "@types/cors": "^2.8.12",
        "@types/express": "^4.17.13",
        "@types/jest": "^27.0.3",
        "@types/node": "^16.11.7",
        "concurrently": "^6.4.0",
        "dotenv": "^10.0.0",
