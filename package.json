{
    "name": "solstice-project",
    "version": "1.0.0",
    "scripts": {
        "prebuild": "tslint -c tslint.json -p tsconfig.json --fix",
        "build": "tsc",
        "prestart": "npm run build",
        "client": "cd client && yarn start",
        "server": "nodemon server.ts",
        "start": "node .",
        "dev": "concurrently --kill-others-on-fail \"yarn server\" \"yarn client\""
    },
    "dependencies": {
        "@metaplex/js": "^4.3.0",
        "@project-serum/anchor": "^0.18.0",
        "@solana/web3.js": "^1.30.2",
        "arweave": "^1.10.18",
        "body-parser": "^1.18.3",
        "express": "^4.16.4",
        "firebase": "^9.5.0",
        "node-fetch": "2",
        "node-p5": "^1.0.4",
        "request": "^2.88.2",
        "seedrandom": "^3.0.5",
        "testweave-sdk": "^0.2.2"
    },
    "devDependencies": {
        "@types/express": "^4.17.13",
        "@types/node": "^16.11.7",
        "concurrently": "^4.0.1",
        "tslint": "^6.1.3",
        "typescript": "^4.4.4"
    },
    "private": true
}
