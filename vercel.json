{
  "version": 2,
  "public": false,
  "builds": [
   { "src": "package.json", "use": "@vercel/static-build" },
   { "src": "/api/server.ts", "use": "@vercel/node" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/server.ts" },
    { "source": "(.*)", "destination": "/index.html" }
   ]
}